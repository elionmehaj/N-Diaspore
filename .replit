modules = ["nodejs-24"]

[[artifacts]]
id = "apps/api"

[[artifacts]]
id = "apps/web"

[[artifacts]]
id = "tools/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
