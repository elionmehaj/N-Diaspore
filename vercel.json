{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "{lib,artifacts}/**",
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

