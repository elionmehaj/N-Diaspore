{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set PORT=5000&& set NODE_ENV=development&& pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/shared": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "groq-sdk": "^1.1.2",
    "mongodb": "^7.1.1",
    "mongodb-memory-server": "^11.0.1",
    "node-cron": "^4.2.1",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
